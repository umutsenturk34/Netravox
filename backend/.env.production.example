PORT=5001
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/cms_panel?appName=Cluster0

# JWT — uzun ve rastgele string kullan
JWT_SECRET=BURAYA_UZUN_RASTGELE_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=BURAYA_FARKLI_UZUN_RASTGELE_STRING
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 — virgülle ayrılmış, boşluksuz
STORAGE_PROVIDER=s3
STORAGE_BUCKET=cms-panel-media
STORAGE_REGION=eu-central-1
STORAGE_ACCESS_KEY=BURAYA_AWS_ACCESS_KEY
STORAGE_SECRET_KEY=BURAYA_AWS_SECRET_KEY
STORAGE_CDN_URL=https://cms-panel-media.s3.eu-central-1.amazonaws.com

# İzin verilen frontend URL'leri — virgülle ayır, boşluksuz
# Örnek: https://panel.vercel.app,https://gusto-kartepe.vercel.app,https://dentcare.vercel.app
CLIENT_URL=https://PANEL_VERCEL_URL,https://GUSTO_VERCEL_URL,https://DENTAL_VERCEL_URL,https://REALTY_VERCEL_URL

# E-posta (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=senturkumut3408@gmail.com
SMTP_PASS=GMAIL_UYGULAMA_SIFRESI
SMTP_FROM="CMS Panel <senturkumut3408@gmail.com>"

# Seed için (Railway üzerinde seed çalıştırırken kullanılır)
SEED_ADMIN_EMAIL=admin@cmspanel.com
SEED_ADMIN_PASSWORD=GUCLU_SIFRE_YAZ
