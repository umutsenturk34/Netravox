PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cms_panel

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Storage Provider: s3 | r2 | backblaze
STORAGE_PROVIDER=s3
STORAGE_BUCKET=cms-panel-media
STORAGE_REGION=eu-central-1
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_ENDPOINT=                  # Cloudflare R2 veya Backblaze için endpoint URL
STORAGE_CDN_URL=https://cdn.yourdomain.com

CLIENT_URL=http://localhost:5173

# Seed (ilk kurulumda)
SEED_ADMIN_EMAIL=admin@cmspanel.com
SEED_ADMIN_PASSWORD=Admin1234!

# E-posta (şifremi unuttum için)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="CMS Panel" <noreply@example.com>
